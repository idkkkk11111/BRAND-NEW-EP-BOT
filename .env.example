# Your bot token from the Discord Developer Portal (Bot tab)
DISCORD_TOKEN=your-bot-token-here

# Your application ID (General Information tab). Only needed for deploy-global.
CLIENT_ID=your-application-id-here

# Where to store data. Locally ./data/db.json is fine.
# On Railway/Render, point this at a mounted volume so data survives restarts,
# e.g. /data/db.json
DATABASE_PATH=./data/db.json
